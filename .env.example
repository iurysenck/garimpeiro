# Copie para .env e preencha. O .env NUNCA é commitado (está no .gitignore).
# O wizard (python garimpeiro.py setup) também gera este arquivo pra você.

# IA que pontua as vagas (escolha o provedor em config.yaml -> ai_provider).
# Sem chave, o app roda mas dá score neutro (sem ranqueamento).
# Gemini é grátis (não precisa de plano pago): https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Alternativas (só se ai_provider = openai/anthropic; ollama é local e não usa chave):
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Telegram (opcional) — alertas das vagas top + erros.
# Token: fale com @BotFather. Chat id: fale com @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
